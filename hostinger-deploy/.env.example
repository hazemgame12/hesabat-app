# Required
DATABASE_URL=postgresql://...
ADMIN_SECRET=change-me-to-a-strong-secret
SESSION_SECRET=change-me-to-another-strong-secret
PORT=3000
NODE_ENV=production

# Uploads persistence (keep OUTSIDE dist so files survive redeploys)
UPLOADS_DIR=/home/USERNAME/nodejs/uploads

# Public URL used in sitemap.xml / robots.txt
SITE_URL=https://hg-audit.com

# Hostinger SMTP for contact form notifications
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@hg-audit.com
SMTP_PASS=your-mailbox-password
SMTP_FROM=info@hg-audit.com
LEAD_NOTIFICATION_TO=info@hg-audit.com

# ── Social Auto-Posting ──
# Credentials can be entered from the dashboard (ربط المنصات) — they are stored
# AES-256 encrypted at rest using SESSION_SECRET/ADMIN_SECRET (or set a dedicated
# CREDENTIALS_SECRET), never as plaintext in the DB. The env vars below remain a
# valid alternative for setting them at the host level.
# CREDENTIALS_SECRET=optional-dedicated-key-for-credential-encryption
# SITE_URL above is also used to build absolute image URLs for FB/Instagram/LinkedIn.
# Facebook Page — requires a verified Meta App with content-publishing review.
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
# Instagram Business account (linked to the Facebook Page).
# Uses FACEBOOK_PAGE_ACCESS_TOKEN by default; set INSTAGRAM_ACCESS_TOKEN to override.
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=
# LinkedIn — requires Marketing Developer Platform approval.
# Author URN, e.g. urn:li:organization:1234567 (or urn:li:person:abc).
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
# Optional: Graph API version (default v21.0)
GRAPH_API_VERSION=v21.0
